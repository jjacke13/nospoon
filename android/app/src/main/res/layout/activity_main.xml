<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="nospoon"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/serverKeyInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Server public key (64 hex chars)"
        android:inputType="textNoSuggestions"
        android:fontFamily="monospace"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/seedInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Client seed (optional, for auth mode)"
        android:inputType="textNoSuggestions|textPassword"
        android:fontFamily="monospace"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/ipInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Client IP (e.g. 10.0.0.2/24)"
        android:text="10.0.0.2/24"
        android:inputType="textNoSuggestions"
        android:fontFamily="monospace"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/connectButton"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Connect"
        android:textSize="18sp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Disconnected"
        android:textSize="16sp"
        android:textColor="#666666" />
</LinearLayout>
